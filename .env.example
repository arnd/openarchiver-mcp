# Base URL of your OpenArchiver instance (without the /api/v1 suffix — it is added automatically).
OPENARCHIVER_BASE_URL=https://openarchiver.example.com

# API key created in OpenArchiver (Settings → API keys, or POST /api/v1/api-keys).
# Needs the permissions: search:archive (search) and read:archive (read email + download).
OPENARCHIVER_API_KEY=replace-with-your-api-key
