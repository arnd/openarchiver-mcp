# Environment for the throwaway OpenArchiver test stack (docker-compose.test.yml).
# These are NOT secrets — this stack is created, used and torn down (`down -v`) per test run.
# Values are literal: docker-compose env_file does not expand ${VAR} / $VAR references.

# --- Application ---
NODE_ENV=production
PORT_BACKEND=4000
PORT_FRONTEND=3000
APP_URL=http://localhost:3000
ORIGIN=http://localhost:3000
SYNC_FREQUENCY=* * * * *
ALL_INCLUSIVE_ARCHIVE=false
INGESTION_WORKER_CONCURRENCY=5

# --- Auto-create the admin on first GET /api/v1/auth/status (no UI setup needed) ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=integration-test-password

# --- PostgreSQL (matches the postgres service env) ---
POSTGRES_DB=open_archive
POSTGRES_USER=admin
POSTGRES_PASSWORD=password
DATABASE_URL=postgresql://admin:password@postgres:5432/open_archive

# --- Meilisearch ---
MEILI_MASTER_KEY=aSampleMasterKey
MEILI_HOST=http://meilisearch:7700
MEILI_INDEXING_BATCH=500

# --- Valkey / Redis (default user + requirepass; no REDIS_USER so AUTH uses 'default') ---
REDIS_HOST=valkey
REDIS_PORT=6379
REDIS_PASSWORD=defaultredispassword
REDIS_TLS_ENABLED=false

# --- Storage ---
STORAGE_TYPE=local
STORAGE_LOCAL_ROOT_PATH=/var/data/open-archiver
BODY_SIZE_LIMIT=100M

# --- Security ---
ENABLE_DELETION=false
JWT_SECRET=integration-test-jwt-secret-not-for-production
JWT_EXPIRES_IN=7d
# 32-byte hex (openssl rand -hex 32) — fixed dummy value for the throwaway stack.
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# --- Apache Tika (attachment text extraction; only active when TIKA_URL is set) ---
TIKA_URL=http://tika:9998
